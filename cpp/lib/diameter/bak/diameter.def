// DIAMETER_INTF(index, NAME, "Full-Name", Command-Code, REQ PXY, APPLICATION_ID, fields)
DIAMETER_INTF(OFR, MO-Forward-Short-Message-Request, 8388645, 1, 1, 16777313,
